# Hosted web proxy (server-only). Do not expose this value through NEXT_PUBLIC_*.
GIDEON_HOSTED_API_INTERNAL_URL=http://127.0.0.1:8787

# Structured capture remains disabled unless the API capability endpoint confirms
# validation, external vault, isolated runtime, discovery, capture, assembly,
# previews, coverage, and audit wiring.
GIDEON_CAPTURE_ISOLATION=local_test
GIDEON_CAPTURE_SECRET_PROVIDER=development_memory
GIDEON_CAPTURE_QUEUE_NAME=gideon-capture-runs
GIDEON_CAPTURE_WORKER_ID=local-capture-worker
GIDEON_CAPTURE_WORKER_CONCURRENCY=1
GIDEON_CAPTURE_MAX_BROWSER_SECONDS=600
GIDEON_CAPTURE_POLICY_VERSION=capture-policy-v1
