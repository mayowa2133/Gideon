        ],
        "finalAssertions": [
          { "type": "visible", "target": { "strategy": "role", "role": "heading", "value": "Why This Decision", "exact": true } },
          { "type": "visible", "target": { "strategy": "role", "role": "heading", "value": "Draft Reply", "exact": true } },
          { "type": "visible", "target": { "strategy": "text", "value": "Approve or reject the draft before any mock send action.", "exact": true } }
        ]
      }
    },
    {
      "id": "review-sensitive-compensation",
      "goalId": "review-sensitive-compensation",
      "resetAdapterId": "signaldraft-empty",
      "verificationAdapterId": "signaldraft-analysis",
      "scenario": {
        "id": "review-sensitive-compensation",
        "framework": "playwright",
        "title": "Review sensitive compensation message",
        "entryPath": "/",
        "sourcePath": "app/ui/streamlit_app.py",
        "steps": [
          { "intent": "Enter the synthetic compensation and sponsorship message.", "action": { "type": "fill", "target": { "strategy": "label", "value": "Paste inbound message", "exact": true }, "valueRef": "fixture:messages.sensitive" }, "riskClass": "synthetic_write" },
          { "intent": "Run the deterministic local analysis.", "action": { "type": "click", "target": { "strategy": "role", "role": "button", "value": "Run Analysis", "exact": true } }, "riskClass": "synthetic_write" },
          { "intent": "Wait for the manual approval gate.", "action": { "type": "wait_for", "assertion": { "type": "visible", "target": { "strategy": "text", "value": "This run requires a manual approval decision before it can be mock sent.", "exact": true } } }, "riskClass": "observe" },
          { "intent": "Confirm the sensitive draft remains unapproved and unsent.", "action": { "type": "wait_for", "assertion": { "type": "visible", "target": { "strategy": "role", "role": "button", "value": "Mock Send", "exact": true } } }, "riskClass": "observe" }
        ],
        "finalAssertions": [
          { "type": "visible", "target": { "strategy": "role", "role": "heading", "value": "Why This Decision", "exact": true } },
          { "type": "visible", "target": { "strategy": "role", "role": "heading", "value": "Draft Reply", "exact": true } },
          { "type": "visible", "target": { "strategy": "text", "value": "This run requires a manual approval decision before it can be mock sent.", "exact": true } }
        ]
      }
    }
  ]
