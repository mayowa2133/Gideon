      "id": "analyze-recruiter-outreach",
      "goalId": "analyze-recruiter-outreach",
      "resetAdapterId": "signaldraft-empty",
      "verificationAdapterId": "signaldraft-analysis",
      "scenario": {
        "id": "analyze-recruiter-outreach",
        "framework": "playwright",
        "title": "Analyze recruiter outreach",
        "entryPath": "/",
        "sourcePath": "app/ui/streamlit_app.py",
        "steps": [
          { "intent": "Enter the synthetic recruiter message.", "action": { "type": "fill", "target": { "strategy": "label", "value": "Paste inbound message", "exact": true }, "valueRef": "fixture:messages.recruiter" }, "riskClass": "synthetic_write" },
          { "intent": "Run the deterministic local analysis.", "action": { "type": "click", "target": { "strategy": "role", "role": "button", "value": "Run Analysis", "exact": true } }, "riskClass": "synthetic_write" },
          { "intent": "Wait for the analysis explanation.", "action": { "type": "wait_for", "assertion": { "type": "visible", "target": { "strategy": "role", "role": "heading", "value": "Why This Decision", "exact": true } } }, "riskClass": "observe" },
