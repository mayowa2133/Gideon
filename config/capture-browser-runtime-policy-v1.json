    "tmpfs": [
      { "path": "/tmp", "sizeBytes": 268435456, "mode": "1770", "uid": 1001, "gid": 1001, "noExec": true, "noSuid": true, "noDev": true },
      { "path": "/work", "sizeBytes": 536870912, "mode": "1770", "uid": 1001, "gid": 1001, "noExec": true, "noSuid": true, "noDev": true }
    ],
    "hostMounts": false,
    "dockerSocket": false
  },
  "limits": {
    "cpus": 1,
    "memoryBytes": 2147483648,
    "pids": 256,
    "wallClockMs": 300000,
    "maxSteps": 100,
    "maxScreenshots": 200,
    "maxArtifactBytes": 524288000
  },
  "network": {
    "proxyOnly": true,
    "browserNetworkInternal": true,
    "allowedSchemes": ["https"],
    "forbiddenCidrs": [
      "0.0.0.0/8", "10.0.0.0/8", "100.64.0.0/10", "127.0.0.0/8", "169.254.0.0/16", "172.16.0.0/12", "192.0.0.0/24", "192.168.0.0/16", "198.18.0.0/15", "224.0.0.0/4", "240.0.0.0/4", "::/128", "::1/128", "fc00::/7", "fe80::/10", "ff00::/8"
