{
  "name": "gideon",
  "version": "0.1.0",
  "private": true,
  "description": "Gideon turns one product walkthrough into short-form video drafts.",
  "author": "Gideon",
  "main": "dist/main/main/main.js",
  "type": "commonjs",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm build:main && vite --host 127.0.0.1",
    "dev:web": "pnpm --filter @gideon/web dev",
    "start": "pnpm build && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "build:desktop": "pnpm build:main && pnpm build:renderer && pnpm build:mcp",
    "build:web": "pnpm --filter @gideon/web build",
    "build": "pnpm build:desktop && pnpm build:web",
    "mcp:server": "node dist/mcp/server.js",
    "worker:hosted": "pnpm build:main && pnpm worker:hosted:run",
    "worker:hosted:run": "node dist/main/main/hostedWorkerProcess.js",
    "worker:hosted:check": "node scripts/check-hosted-worker-config.mjs",
    "capture:worker:check": "node scripts/check-capture-worker-config.mjs",
    "capture:pilot": "pnpm build:main && node dist/main/main/nexusReachPilot.js",
    "avatar:worker:check": "node scripts/check-avatar-worker-config.mjs",
    "avatar:worker:canary": "node scripts/run-avatar-worker-canary.mjs",
    "provider:canary": "pnpm build:main && node dist/main/main/providerCanaryCli.js",
    "smoke:local-core": "pnpm build && node scripts/run-local-core-smoke.mjs",
    "staging:check": "node scripts/check-staging-readiness.mjs",
    "staging:smoke": "node scripts/run-staging-smoke.mjs",
    "staging:mcp:smoke": "node scripts/run-staging-mcp-smoke.mjs",
    "production:check": "node scripts/run-production-readiness-gate.mjs",
    "production:promote:check": "node scripts/run-production-promotion-gate.mjs",
    "production:evidence:check": "node scripts/check-production-promotion-evidence.mjs",
    "production:github-config:check": "node scripts/check-live-promotion-github-config.mjs",
    "production:github-settings:check": "node scripts/check-github-live-promotion-settings.mjs",
    "production:github-evidence:check": "node scripts/check-github-promotion-evidence.mjs",
    "production:github-receipt:check": "node scripts/check-github-promotion-receipt.mjs",
    "production:github-archive:check": "node scripts/check-github-promotion-archive.mjs",
    "production:github-promote:run": "node scripts/run-github-live-promotion.mjs",
    "production:live-env:check": "node scripts/check-live-promotion-env.mjs",
    "production:fixtures:materialize": "node scripts/materialize-live-promotion-fixtures.mjs",
    "production:mcp:check": "node scripts/check-mcp-access-policy.mjs",
    "production:prompt:check": "node scripts/check-prompt-rollout-policy.mjs",
    "production:billing:check": "node scripts/check-billing-reconciliation.mjs",
    "production:db:check": "node scripts/check-postgres-policy.mjs",
    "production:queue:check": "node scripts/check-bullmq-policy.mjs",
    "production:observability:check": "node scripts/check-observability-policy.mjs",
    "production:storage:check": "node scripts/check-storage-policy.mjs",
    "production:storage-download:smoke": "node scripts/run-storage-download-smoke.mjs",
    "production:tts:check": "node scripts/check-tts-policy.mjs",
    "production:provider-canary-report:check": "node scripts/check-provider-canary-report.mjs",
    "production:release-receipt:check": "node scripts/check-release-receipt.mjs",
    "db:migrate": "node scripts/migrate-postgres.mjs",
    "lint": "node scripts/lint-repository.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.mcp.json && pnpm --filter @gideon/web typecheck",
    "test": "vitest run",
    "test:capture": "vitest run src/shared/productFlowCapture.test.ts src/main/nexusReachPilot.test.ts src/main/captureCredentials.test.ts src/main/postgresCaptureCredentialMetadataStore.test.ts src/main/captureNetworkPolicy.test.ts src/main/captureEnvironmentProbe.test.ts src/main/captureRateLimit.test.ts src/main/productFlowCompiler.test.ts src/main/captureMedia.test.ts src/main/playwrightCaptureExecutor.integration.test.ts src/main/captureInventoryCrawler.integration.test.ts src/main/captureLoginAdapters.integration.test.ts src/main/flowDiscovery.test.ts src/main/discoveryService.test.ts src/main/discoveryRunCoordinator.test.ts src/main/discoveryRunWorker.test.ts src/main/flowRepair.test.ts src/main/captureEvaluation.test.ts src/main/repositoryEvidence.test.ts src/main/testScenarioImport.test.ts src/main/captureCoverage.test.ts src/main/captureCoverageService.test.ts src/main/postRunCoverage.test.ts src/main/captureObservability.test.ts src/main/captureAudit.test.ts src/main/environmentValidationCoordinator.test.ts src/main/environmentValidationWorker.test.ts src/main/captureRunCoordinator.test.ts src/main/captureRunWorker.test.ts src/main/captureRunService.test.ts src/main/captureExecutionRetry.test.ts src/main/captureAssemblyCoordinator.test.ts src/main/captureAssemblyWorker.test.ts src/main/capturePreviewService.test.ts src/main/storageCapturePreviewSigner.test.ts src/main/captureDeletion.test.ts src/main/captureQueue.test.ts src/main/isolatedCaptureRuntime.test.ts src/main/captureService.test.ts src/main/postgresCaptureRepository.test.ts",
    "test:redis": "vitest run src/main/jobQueue.redis.test.ts",
    "test:web": "pnpm --filter @gideon/web test",
    "test:e2e": "playwright test --config apps/web/playwright.config.ts",
    "test:watch": "vitest",
    "package:mac": "pnpm build && electron-builder --mac dmg zip --config.mac.identity=null --publish=never",
    "package:mac:signed": "pnpm build && electron-builder --mac dmg zip --publish=never",
    "release:mac:check": "node scripts/check-macos-release.mjs",
    "hosted:review:check": "node scripts/check-hosted-review-policy.mjs",
    "dist:mac": "pnpm package:mac"
  },
  "build": {
    "appId": "com.gideon.desktop",
    "productName": "Gideon",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "bullmq": "^5.79.2",
    "pg": "^8.22.0",
    "pureimage": "^0.4.18",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
